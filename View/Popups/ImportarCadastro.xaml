<Window x:Class="TCC_Assiduidade.View.Popups.ImportarCadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TCC_Assiduidade.View"
        xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
        mc:Ignorable="d"
        Title="Processo de Importação" 
        Height="590" Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="InputStyleWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="5"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            <TextBlock x:Name="PlaceholderText" 
                               Text="{TemplateBinding Tag}" 
                               Foreground="#99AAB5" 
                               Style="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=FontSize}"
                               IsHitTestVisible="False" 
                               VerticalAlignment="Center" 
                               Margin="12,0" 
                               Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#E0EBEB"/>
            <Setter Property="BorderBrush" Value="#BFCFCF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0,30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="GridBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" />
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="30" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M7,10L12,15L17,10H7Z" Fill="#2A5C60" HorizontalAlignment="Center" VerticalAlignment="Center" Width="14" Height="14" Stretch="Uniform" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="White" BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,1,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopUpActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A5C60"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopUpCancelButtonStyle" TargetType="Button" BasedOn="{StaticResource PopUpActionButtonStyle}">
            <Setter Property="Background" Value="#757575"/>
        </Style>
    </Window.Resources>

    <Border Background="#E5EFEF" CornerRadius="12" BorderBrush="#B6C9C9" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Importação de Cadastro de Alunos" 
                           FontSize="20" FontWeight="Bold" Foreground="#11181C" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>

                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0" 
                        Foreground="#889898" FontSize="18" FontWeight="Bold" Cursor="Hand" 
                        Click="BtnCancelar_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                <StackPanel>

                    <TextBlock Text="Passo 1: Definição da Turma" FontSize="15" FontWeight="Bold" Foreground="#222" Margin="0,0,0,8"/>
                    <Border BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="8" Padding="15" Background="#F0F7F7" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <RadioButton Content="Criar Nova Turma" 
                                             IsChecked="{Binding IsNovaTurma, Mode=TwoWay}" 
                                             FontSize="14" Foreground="#11181C" Margin="0,0,25,0" Cursor="Hand"/>
                                <RadioButton Content="Turma Existente" 
                                             IsChecked="{Binding IsTurmaExistente, Mode=TwoWay}" 
                                             FontSize="14" Foreground="#11181C" Cursor="Hand"/>
                            </StackPanel>

                            <Grid Visibility="{Binding IsNovaTurma, Converter={StaticResource BoolToVis}}">
                                <TextBox Style="{StaticResource InputStyleWithPlaceholder}" 
                                         Tag="Digite o nome da nova turma"
                                         Text="{Binding NovaTurmaNome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#E0EBEB" 
                                         BorderBrush="#BFCFCF" 
                                         BorderThickness="1"
                                         Height="38" 
                                         FontSize="14" 
                                         VerticalContentAlignment="Center" 
                                         Padding="8,0"/>
                            </Grid>

                            <Grid Visibility="{Binding IsTurmaExistente, Converter={StaticResource BoolToVis}}">
                                <ComboBox x:Name="CbTurmas" 
                                           Height="38" 
                                           Style="{StaticResource ComboBoxStyle}"
                                           FontSize="14" 
                                           VerticalContentAlignment="Center"
                                           ItemsSource="{Binding Turmas}"
                                           SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
                                           DisplayMemberPath="Nome">
                                </ComboBox>
                                <TextBlock Text="Selecionar a turma de destino" 
                                    Foreground="#99AAB5" 
                                    FontSize="14" 
                                    VerticalAlignment="Center" 
                                    Margin="10,0,30,0"
                                    IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem, ElementName=CbTurmas, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Passo 2: Data de Entrada na Turma" FontSize="15" FontWeight="Bold" Foreground="#222" Margin="0,0,0,8"/>
                    <Border BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="8" Padding="15" Background="#F0F7F7" Margin="0,0,0,15">
                        <StackPanel>
                            <Border BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="5" Background="White" Height="38">
                                <DatePicker SelectedDate="{Binding DataEntrada, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            VerticalAlignment="Center"
                                            Padding="5,0"
                                            FontSize="14"/>
                            </Border>
                            <TextBlock Text="* Se deixada em branco, será utilizada a data atual do sistema." 
                                       FontSize="11" 
                                       FontStyle="Italic" 
                                       Foreground="#55686A" 
                                       Margin="2,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Passo 3: Seleção de arquivo" FontSize="15" FontWeight="Bold" Foreground="#222" Margin="0,0,0,8"/>
                    <Border BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="8" Padding="15" Background="#F0F7F7">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource PopUpActionButtonStyle}" Width="150" Height="38" Command="{Binding SelecionarArquivoCommand}" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,11L16,15H13V18H11V15H8L12,11Z" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Escolher Arquivo" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBox Grid.Column="1" BorderBrush="Transparent" Height="38" Margin="10,0,0,0" IsReadOnly="True" Background="Transparent" VerticalContentAlignment="Center" Padding="8,0" FontSize="14" Foreground="#556666"
                                         Text="{Binding CaminhoArquivo, Mode=OneWay}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2">
                <Button Content="Iniciar Importação" Style="{StaticResource PopUpActionButtonStyle}" HorizontalAlignment="Stretch" Height="40" FontSize="15" Cursor="Hand"
                        Command="{Binding IniciarImportacaoCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
<Window x:Class="TCC_Assiduidade.View.Popups.ResumoAula"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
        xmlns:local="clr-namespace:TCC_Assiduidade.View.Popups"
        mc:Ignorable="d" 
        Title="Resumo da Aula" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="12"
            Margin="15"
            Padding="25">

        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*"/>
                <ColumnDefinition Width="37*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15" Grid.ColumnSpan="2">
                <TextBlock Text="Relatório de Ausentes" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#11181C"/>

                <Button Content="✕" 
                        HorizontalAlignment="Right" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Foreground="#888" 
                        FontSize="18" 
                        FontWeight="Bold" 
                        Cursor="Hand" 
                        FocusVisualStyle="{x:Null}"
                        Click="BtnFechar_Click"/>
            </Grid>

            <Border Grid.Row="1" Background="#ECF8F6" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#B0C8D6" BorderThickness="1" Grid.ColumnSpan="2">
                <StackPanel>
                    <TextBlock FontSize="14" Margin="0,0,0,6" Foreground="#1F2933">
                        <Run Text="Data da Aula: " FontWeight="Bold" Foreground="#236B73"/>
                        <Run Text="{Binding AulaVisualizar.Data, StringFormat={}{0:dd/MM/yyyy}, FallbackValue='-'}" />
                    </TextBlock>
                    <TextBlock FontSize="14" Margin="0,0,0,6" Foreground="#1F2933">
                        <Run Text="Turma: " FontWeight="Bold" Foreground="#236B73"/>
                        <Run Text="{Binding AulaVisualizar.Turma, FallbackValue='-'}" />
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#1F2933">
                        <Run Text="Total de Ausentes: " FontWeight="Bold" Foreground="#236B73"/>
                        <Run Text="{Binding AulaVisualizar.NumeroAusentes, FallbackValue='0'}" FontWeight="SemiBold" Foreground="#AA3333"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,114,0,15" Grid.ColumnSpan="2" Grid.RowSpan="2">
                <TextBlock HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14" 
                           FontStyle="Italic" 
                           Foreground="#666">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Text" Value="Não houve ausências nesta aula."/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AlunosAusentes.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <DataGrid ItemsSource="{Binding AlunosAusentes}" 
                          AutoGenerateColumns="False" 
                          Background="Transparent" 
                          BorderBrush="#CBD2D9"
                          BorderThickness="1" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E2E8F0"
                          IsReadOnly="True"
                          RowHeight="38"
                          FontSize="14"
                          Foreground="#1F2933">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#11181C" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#11181C" />
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DDEEEB"/>
                                    <Setter Property="Foreground" Value="#11181C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="AlinhamentoTextoStyle" TargetType="TextBlock">
                            <Setter Property="Padding" Value="12,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F4F8"/>
                            <Setter Property="Foreground" Value="#555555"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#CBD2D9"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="110" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                        <DataGridTextColumn Header="Nome do Aluno" Binding="{Binding Aluno}" Width="2*" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                        <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="2.5*" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Button Grid.Row="3" 
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding GerarHtmlCommand}"
                    CommandParameter="{Binding AulaVisualizar}"
                    Height="38" 
                    Width="160"
                    HorizontalAlignment="Left"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}" Grid.Column="1" Margin="138,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M19,3H5C3.89,3 3,3.9 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M9,17H7V10H9V17M13,17H11V7H13V17M17,17H15V12H17V17Z"
                          Fill="White" Width="15" Height="15" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="Gerar HTML" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</Window>
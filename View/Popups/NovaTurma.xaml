<Window x:Class="TCC_Assiduidade.View.Popups.NovaTurma"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TCC_Assiduidade.View"
        xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Height="225"
        Width="280">

    <Window.Resources>
        <Style x:Key="CleanInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                            <TextBlock x:Name="PlaceholderText" 
                                       Text="{TemplateBinding Tag}" 
                                       Foreground="#9e9e9e" 
                                       FontSize="14" 
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Padding="10,0"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopUpActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#ECF8F6"
        CornerRadius="12"
        BorderBrush="#B6C9C9"
        BorderThickness="1"
        Margin="10">

        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                          Direction="270"
                          ShadowDepth="3"
                          Opacity="0.3"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Cadastrar Nova Turma" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Nome da Turma" FontSize="13" Foreground="#000" Margin="0,0,0,5"/>

                <Border BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="5" Background="White" Height="38">
                    <TextBox Style="{StaticResource CleanInputStyle}" 
                             Tag="Digite o nome da nova turma..."
                             Text="{Binding NomeNovaTurma, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancelar" Width="90" Height="38" Background="#757575" Style="{StaticResource PopUpActionButtonStyle}" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Salvar" Width="90" Height="38" Style="{StaticResource PopUpActionButtonStyle}" Command="{Binding SalvarTurmaCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
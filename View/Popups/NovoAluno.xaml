<Window x:Class="TCC_Assiduidade.View.Popups.NovoAluno"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
        mc:Ignorable="d" 
        Title="Cadastrar Aluno" 
        Height="465" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <Style x:Key="CleanInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>

                            <TextBlock x:Name="PlaceholderText" 
                               Text="{TemplateBinding Tag}" 
                               Foreground="#9e9e9e" 
                               FontSize="14" 
                               IsHitTestVisible="False" 
                               VerticalAlignment="Center" 
                               Padding="10,0"
                               Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#BFCFCF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0,30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="GridBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" />
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="30" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M7,10L12,15L17,10H7Z" Fill="#2A5C60" HorizontalAlignment="Center" VerticalAlignment="Center" Width="14" Height="14" Stretch="Uniform" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="White" BorderBrush="#BFCFCF" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,1,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PopUpActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#ECF8F6" CornerRadius="12" BorderBrush="#B6C9C9" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="181*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Novo Aluno" FontSize="20" FontWeight="Bold" Foreground="#11181C" Margin="0,0,0,20" Grid.ColumnSpan="2"/>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Matrícula" FontSize="13" Foreground="#000" Margin="0,0,0,5"/>
                    <Border BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="5" Background="White" Height="38">
                        <TextBox Style="{StaticResource CleanInputStyle}" 
                 Tag="Ex: 20261234" 
                 Text="{Binding Matricula, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Nome Completo" FontSize="13" Foreground="#000" Margin="0,0,0,5"/>
                    <Border BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="5" Background="White" Height="38">
                        <TextBox Style="{StaticResource CleanInputStyle}" 
                 Tag="Digite o nome do aluno" 
                 Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="E-mail" FontSize="13" Foreground="#000" Margin="0,0,0,5"/>
                    <Border BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="5" Background="White" Height="38">
                        <TextBox Style="{StaticResource CleanInputStyle}" 
                 Tag="exemplo@dominio.com" 
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Turma" FontSize="13" Foreground="#000" Margin="0,0,0,5"/>
                    <Grid>
                        <ComboBox x:Name="CbTurmas" 
               Height="38" 
               Style="{StaticResource ComboBoxStyle}"
               FontSize="14" 
               VerticalContentAlignment="Center"
               ItemsSource="{Binding Turmas}"
               SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
               DisplayMemberPath="Nome">
                        </ComboBox>

                        <TextBlock Text="Selecionar a turma de destino" 
        Foreground="#9e9e9e" 
        FontSize="14" 
        VerticalAlignment="Center" 
        Margin="10,0,30,0"
        IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=CbTurmas, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Grid.Column="1">
                <Button Content="Cancelar" Width="90" Height="38" Background="#757575" Style="{StaticResource PopUpActionButtonStyle}" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Salvar" Width="90" Height="38" Style="{StaticResource PopUpActionButtonStyle}" Command="{Binding SalvarAlunoCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
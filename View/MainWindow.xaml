        <StreamGeometry x:Key="IconeAlunos">M12,3L1,9L12,15L21,10.09V17H23V9M4.41,11.5L12,15.64L19.59,11.5L12,7.36M12,17C10.15,17 8.44,16.4 7,15.39V18C7,19.66 9.24,21 12,21C14.76,21 17,19.66 17,18V15.39C15.56,16.4 13.85,17 12,17Z</StreamGeometry>
        <StreamGeometry x:Key="IconeArquivoUpload">M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,11L16,15H13V18H11V15H8L12,11Z</StreamGeometry>
        <StreamGeometry x:Key="IconeAulas">M19,2H5C3.89,2 3,2.89 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4C21,2.89 20.1,2 19,2M19,20H5V4H7V11L9.5,8.5L12,11V4H19V20Z</StreamGeometry>

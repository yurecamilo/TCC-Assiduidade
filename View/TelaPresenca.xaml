<Window x:Class="TCC_Assiduidade.View.TelaPresenca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Presença"
        Height="499"
        Width="675"
        WindowStartupLocation="CenterScreen">
    <!-- MODIFICAÇÃO 1: Removemos o Loaded="Window_Loaded" porque a ViewModel busca as turmas sozinha ao nascer -->

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Tela de Importação de Presença"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Turma:"/>

            <!-- MODIFICAÇÃO 2: Adicionados o ItemsSource para encher a lista e SelectedItem para capturar a escolha -->
            <ComboBox x:Name="cbTurmas"
                      ItemsSource="{Binding Turmas}"
                      SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
                      DisplayMemberPath="Nome"
                      Height="30"
                      Margin="0,5,0,15"
                      VerticalContentAlignment="Center"/>

            <!-- MODIFICAÇÃO 3: Trocado 'Click' por 'Command' para disparar a leitura do CSV de presenças -->
            <Button Content="Importar CSV de Presença"
                    Command="{Binding ImportarPresencaCommand}"
                    Height="40"/>

            <!-- MODIFICAÇÃO 4: Adicionado o Binding para receber o TextoLog do processamento e IsReadOnly para proteção -->
            <TextBox x:Name="tbDados"
                     Text="{Binding TbDados, Mode=OneWay}"
                     IsReadOnly="True"
                     Margin="0,20,0,0"
                     Height="220"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

    </Grid>
</Window>
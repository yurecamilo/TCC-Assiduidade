<UserControl x:Class="TCC_Assiduidade.View.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TCC_Assiduidade.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid Margin="20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="📄" Foreground="White" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="199*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Text="Bem-Vindo, Professor" Foreground="White" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20" Grid.ColumnSpan="2"/>

        <Border Background="#e2f1f1" CornerRadius="15" Padding="15" MaxWidth="600" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,57,0,0" Width="531" Height="213">
            <StackPanel>
                <TextBlock Text="Ações Rápidas" Foreground="#11181C" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <Button Style="{StaticResource ActionButtonStyle}" Click="BtnImportarCadastro_Click" Cursor="Hand">
                    <TextBlock Text="Importar Cadastro Alunos" FontSize="16" FontWeight="Medium"/>
                </Button>

                <Button Style="{StaticResource ActionButtonStyle}" Click="BtnImportarChamada_Click" Cursor="Hand">
                    <TextBlock Text="Importar Chamada CSV" FontSize="16" FontWeight="Medium"/>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

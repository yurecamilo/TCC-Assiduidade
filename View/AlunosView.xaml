<UserControl x:Class="TCC_Assiduidade.View.AlunosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TCC_Assiduidade.View"
             xmlns:vm="clr-namespace:TCC_Assiduidade.ViewModel"
             xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <Geometry x:Key="IconeVisualizar">M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z</Geometry>
        <Geometry x:Key="IconeEditar">M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z</Geometry>
        <Geometry x:Key="IconeExcluir">M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z</Geometry>
        <Geometry x:Key="IconeAdicionar">M19,11H13V5H11V11H5V13H11V19H13V13H19V11Z</Geometry>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyleWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            <TextBlock x:Name="PlaceholderText" Text="{TemplateBinding Tag}" Foreground="#99AAB5" FontSize="14" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0,30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="GridBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" />

                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />

                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="30" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M7,10L12,15L17,10H7Z" Fill="#236B73" HorizontalAlignment="Center" VerticalAlignment="Center" Width="14" Height="14" Stretch="Uniform" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="White" BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,1,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlertButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A6984"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gerenciamento de Alunos" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#ECF8F6" CornerRadius="15" Padding="20">
            <StackPanel>
                <TextBlock Text="Filtragem e Busca" FontSize="18" FontWeight="Bold" Foreground="#11181C" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="#555" Margin="0,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Busca Avançada (Nome, Matrícula)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" HorizontalAlignment="Left" Width="250" Style="{StaticResource InputStyleWithPlaceholder}" Tag="Digite o nome ou matrícula" Text="{Binding TextoBusca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Limpar busca" Style="{StaticResource AlertButtonStyle}" Height="38" Width="100" Margin="8,0,0,0" FontSize="14" Cursor="Hand" Command="{Binding LimparBuscaCommand}"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Left" Margin="20,0,0,0" Grid.Column="1">
                        <TextBlock Margin="0,0,0,5" Text="Selecionar Turma" Foreground="#555" FontSize="13" FontWeight="SemiBold"/>

                        <Grid>
                            <ComboBox x:Name="CbTurmas" 
                                       Height="38" 
                                       Style="{StaticResource ComboBoxStyle}"
                                       FontSize="14" 
                                       ItemsSource="{Binding Turmas}"
                                       SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
                                       DisplayMemberPath="Nome">
                            </ComboBox>

                            <TextBlock Text="Selecionar a turma de destino" 
                                        Foreground="#99AAB5" 
                                        FontSize="14" 
                                        VerticalAlignment="Center" 
                                        Margin="10,0,30,0"
                                        IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, ElementName=CbTurmas, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#ECF8F6" CornerRadius="15" Padding="20" ClipToBounds="True" MaxHeight="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Relação Geral de Alunos" FontSize="18" FontWeight="SemiBold" Foreground="#11181C" Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding Alunos}" Background="Transparent" BorderThickness="0" RowBackground="Transparent" AlternatingRowBackground="#DDEEEB" GridLinesVisibility="None" HeadersVisibility="Column" IsReadOnly="True" FontSize="16" Foreground="#11181C" ColumnWidth="*" RowHeight="42">
                        <DataGrid.Resources>
                            <Style x:Key="AlinhamentoTextoStyle" TargetType="TextBlock">
                                <Setter Property="Padding" Value="12,0,0,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#11181C" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#11181C" />
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DDEEEB"/>
                                        <Setter Property="Foreground" Value="#11181C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#B0C8D6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="120" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                            <DataGridTextColumn Header="NOME" Binding="{Binding Nome}" Width="1.7*" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                            <DataGridTextColumn Header="TURMA" Binding="{Binding Turma}" Width="1*" ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>
                            <DataGridTemplateColumn Header="AÇÕES" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Command="{Binding DataContext.VisualizarDadosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconeVisualizar}" Fill="#236B73" Width="16" Height="16" Stretch="Uniform"/>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0" Command="{Binding DataContext.EditarTurmaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconeEditar}" Fill="#236B73" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding DataContext.ExcluirTurmaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconeExcluir}" Fill="#AA3333" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#ECF8F6" CornerRadius="15" Padding="18" Width="370" VerticalAlignment="Center" Margin="15,0,0,0" Visibility="{Binding AlunoSelecionado, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Perfil Rápido do Aluno" FontSize="16" FontWeight="Bold" Foreground="#11181C" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#888" FontSize="16" FontWeight="Bold" Cursor="Hand" Command="{Binding DataContext.FecharPerfilCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </Grid>
                    <Border Background="#DDEEEB" Padding="12" CornerRadius="8" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding AlunoSelecionado.Nome, FallbackValue='Nenhum selecionado'}" FontSize="16" FontWeight="Bold" Foreground="#236B73" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AlunoSelecionado.Matricula, StringFormat='Matrícula: {0}', FallbackValue='-'}" FontSize="13" Foreground="#555" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding AlunoSelecionado.Turma, FallbackValue='-'}" FontSize="13" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="13" Foreground="#555" HorizontalAlignment="Center" Margin="0,2,0,0">
                                <Run FontWeight="Bold"/><Run Text="{Binding AlunoSelecionado.Email, FallbackValue='-'}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Grid>
                        <UniformGrid x:Name="DadosAssiduidade" Columns="2" Rows="2" Margin="0,0,0,15">
                            <UniformGrid.Style>
                                <Style TargetType="UniformGrid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TemAulas}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </UniformGrid.Style>

                            <Border BorderBrush="#B0C8D6" BorderThickness="0,0,1,1" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="Assiduidade Geral" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AlunoSelecionado.DadosFrequencia.Assiduidade, StringFormat={}{0}%, FallbackValue='0%'}" FontSize="22" FontWeight="Bold" Foreground="#236B73" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#B0C8D6" BorderThickness="0,0,0,1" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="Total de Faltas" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AlunoSelecionado.DadosFrequencia.TotalFaltas, StringFormat={}{0} Faltas, FallbackValue='0 Faltas'}" FontSize="20" FontWeight="Bold" Foreground="#AA3333" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#B0C8D6" BorderThickness="0,0,1,0" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="Aulas ministradas" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AlunoSelecionado.DadosFrequencia.TotalAulas, StringFormat={}{0} Aulas, FallbackValue='0 Aulas'}" FontSize="20" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Nenhuma aula registrada para este aluno/turma." 
           FontSize="14" Foreground="#777" FontStyle="Italic" 
           VerticalAlignment="Center" HorizontalAlignment="Center" 
           TextWrapping="Wrap" Margin="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AlunoSelecionado.TemAulas}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
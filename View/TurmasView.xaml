<UserControl x:Class="TCC_Assiduidade.View.TurmasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TCC_Assiduidade.View"
             xmlns:vm="clr-namespace:TCC_Assiduidade.ViewModel"
             xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <Geometry x:Key="IconeEditar">M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z</Geometry>
        <Geometry x:Key="IconeExcluir">M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z</Geometry>
        <Geometry x:Key="IconeBuscar">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.03,15.14C11.9,16 10.76,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</Geometry>
        <Geometry x:Key="IconeAdicionar">M19,11H13V5H11V11H5V13H11V19H13V13H19V11Z</Geometry>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputStyleWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5,35,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="5"/>

                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>

                            <Path Data="{StaticResource IconeBuscar}" 
                                  Fill="#99AAB5" 
                                  Width="16" 
                                  Height="16" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Right" 
                                  Margin="0,0,12,0" 
                                  IsHitTestVisible="False"/>

                            <TextBlock x:Name="PlaceholderText" 
                                       Text="{TemplateBinding Tag}" 
                                       Foreground="#99AAB5" 
                                       FontSize="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=FontSize}"
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Margin="12,0" 
                                       Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlertButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A6984"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gerenciamento de Turmas" 
                   Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBox x:Name="CampoBusca"
                         Style="{StaticResource InputStyleWithPlaceholder}" 
                         Tag="Digite o nome da turma"
                         Width="218" 
                         Text="{Binding TextoBusca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Limpar busca" 
                        Style="{StaticResource AlertButtonStyle}"
                        Height="38"
                        Width="100"
                        Margin="8,0,0,0"
                        FontSize="14"
                        ToolTip="Limpar busca"
                        Cursor="Hand"
                        Command="{Binding LimparBuscaCommand}">
                        
                </Button>
            </StackPanel>

            <Button Grid.Column="1" 
                    Style="{StaticResource ActionButtonStyle}" 
                    Command="{Binding AbrirPopupCadastroCommand}"
                    Height="38"
                    Width="130"
                    Padding="15,0"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconeAdicionar}"
                          Fill="White" 
                          Width="14" 
                          Height="14" 
                          Stretch="Uniform" 
                          Margin="0,0,8,0"/>

                    <TextBlock Text="Adicionar" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="#ECF8F6" 
                    CornerRadius="15" 
                    Padding="20" 
                    ClipToBounds="True" 
                    VerticalAlignment="Top" 
                    MaxHeight="400">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Relação Geral de Turmas" FontSize="18" FontWeight="SemiBold" Foreground="#11181C" Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1" x:Name="GridTurmas" AutoGenerateColumns="False" 
                              ItemsSource="{Binding Turmas}"
                              SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="Transparent" AlternatingRowBackground="#DDEEEB"
                              GridLinesVisibility="None" HeadersVisibility="Column" IsReadOnly="True"
                              FontSize="16" Foreground="#11181C" ColumnWidth="*" RowHeight="42">

                        <DataGrid.Resources>
                            <Style x:Key="AlinhamentoTextoStyle" TargetType="TextBlock">
                                <Setter Property="Padding" Value="12,0,0,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#B0C8D6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NOME" Binding="{Binding Nome}" Width="*" 
                                                ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>

                            <DataGridTextColumn Header="N° DE ALUNOS" Binding="{Binding QuantidadeAlunos}" Width="*" 
                                                ElementStyle="{StaticResource AlinhamentoTextoStyle}"/>

                            <DataGridTemplateColumn Header="AÇÕES" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Width="100" VerticalAlignment="Center">
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"
                                                    Command="{Binding DataContext.EditarTurmaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconeEditar}" Fill="#236B73" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>

                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.ExcluirTurmaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconeExcluir}" Fill="#AA3333" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
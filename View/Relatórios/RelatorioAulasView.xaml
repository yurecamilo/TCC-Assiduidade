<UserControl x:Class="TCC_Assiduidade.View.Relatórios.RelatorioAulasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TCC_Assiduidade.View.Relatórios"
             xmlns:vm="clr-namespace:TCC_Assiduidade.ViewModel.Relatorios"
             xmlns:conv="clr-namespace:TCC_Assiduidade.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <Geometry x:Key="IconeVisualizar">M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z</Geometry>
     
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#236B73"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputStyleWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="5"/>

                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>

                            <TextBlock x:Name="PlaceholderText" 
                                       Text="{TemplateBinding Tag}" 
                                       Foreground="#99AAB5" 
                                       Style="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=FontSize}"
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Margin="12,0" 
                                       Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0,30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="GridBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" />
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />

                            <ToggleButton x:Name="ToggleButton" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" HorizontalAlignment="Right" Width="30" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path x:Name="Arrow" Data="M7,10L12,15L17,10H7Z" Fill="#236B73" HorizontalAlignment="Center" VerticalAlignment="Center" Width="14" Height="14" Stretch="Uniform" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" BorderBrush="#B0C8D6" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,1,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlertButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A6984"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Command="{Binding VoltarCommand}" Style="{StaticResource ActionButtonStyle}" 
        Background="Transparent" HorizontalAlignment="Left" Margin="0,0,0,5">
            <TextBlock Text="← Voltar para Relatórios" FontWeight="Regular"/>
        </Button>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Relatório de Aula" Foreground="#ffffff" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Selecione a aula desejada para gerar o relatório" Foreground="#A0AAB0" FontSize="16"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#ECF8F6" CornerRadius="15" Padding="20">
            <StackPanel>
                <TextBlock Text="Filtragem e Busca" FontSize="18" FontWeight="Bold" Foreground="#11181C" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Filtrar por Período (Data da Aula)" Foreground="#555" Margin="0,0,0,5" FontSize="13" FontWeight="SemiBold"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <DatePicker Style="{StaticResource InputStyle}" 
                                            SelectedDate="{Binding DataInicio, Mode=TwoWay, TargetNullValue=''}"
                                            Language="pt-BR">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="Text" Value="Selecionar data"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Grid>

                            <Grid Grid.Column="1" Margin="0,0,10,0">
                                <DatePicker Style="{StaticResource InputStyle}" 
                                            SelectedDate="{Binding DataFim, Mode=TwoWay, TargetNullValue=''}"
                                            Language="pt-BR">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="Text" Value="Selecionar data"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Grid>

                            <Button Grid.Column="2" 
                                    Content="Limpar datas" 
                                    Style="{StaticResource AlertButtonStyle}"
                                    Padding="10,0"
                                    Width="95"
                                    FontSize="14"
                                    Cursor="Hand"
                                    Command="{Binding LimparDatasCommand}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Selecionar Turma" Foreground="#555" Margin="0,0,0,5" FontSize="13" FontWeight="SemiBold"/>
                        <ComboBox Style="{StaticResource ComboBoxStyle}" 
                                  ItemsSource="{Binding Turmas}"
                                  SelectedValue="{Binding TurmaSelecionada}"
                                  DisplayMemberPath="Nome"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Border Background="#ECF8F6" 
                    CornerRadius="15" 
                    Padding="20" 
                    ClipToBounds="True" 
                    VerticalAlignment="Top" 
                    MaxHeight="290">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                   
                    <TextBlock Grid.Row="0" Text="Relação Geral de Aulas" FontSize="18" FontWeight="SemiBold" Foreground="#11181C" Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1" x:Name="GridAulas" AutoGenerateColumns="False" 
                              ItemsSource="{Binding Aulas}"
                                SelectedItem="{Binding AulaSelecionada, Mode=TwoWay}"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="Transparent" AlternatingRowBackground="#DDEEEB"
                              GridLinesVisibility="None" HeadersVisibility="Column" IsReadOnly="True"
                              FontSize="14" Foreground="#11181C" ColumnWidth="*" RowHeight="38">

                        <DataGrid.Resources>
                            <Style x:Key="AlinhamentoTextoStyle" TargetType="TextBlock">
                                <Setter Property="Padding" Value="12,0,0,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>

                            <Style x:Key="CelulaClicavelStyle" TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#11181C" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#11181C" />
                                </Style.Resources>

                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#236B73"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#B0C8D6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="SelecaoAulaUnica" 
                             IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="DATA" Binding="{Binding Data, StringFormat={}{0:dd/MM/yyyy}}" Width="140" ElementStyle="{StaticResource AlinhamentoTextoStyle}" CellStyle="{StaticResource CelulaClicavelStyle}"/>
                            <DataGridTextColumn Header="TURMA" Binding="{Binding Turma}" Width="1.2*" ElementStyle="{StaticResource AlinhamentoTextoStyle}" CellStyle="{StaticResource CelulaClicavelStyle}"/>
                            <DataGridTextColumn Header="N° DE FALTAS" Binding="{Binding NumeroAusentes}" Width="1*" ElementStyle="{StaticResource AlinhamentoTextoStyle}" CellStyle="{StaticResource CelulaClicavelStyle}"/>

                            <DataGridTemplateColumn Header="AÇÕES" Width="120">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Width="100" VerticalAlignment="Center" >
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                            FocusVisualStyle="{x:Null}"
                            Click="BtnVisualizarAula_Click">
                                                <TextBlock Text="Visualizar" HorizontalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Button Grid.Row="6" 
            Style="{StaticResource ActionButtonStyle}"
            Command="{Binding GerarHtmlCommand}"
            CommandParameter="{Binding AulaSelecionada}"
            Height="45" 
            HorizontalAlignment="Stretch"
            Cursor="Hand"
            FocusVisualStyle="{x:Null}" Grid.Column="1" >
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Gerar HTML" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
        </Button>
    </Grid>
</UserControl>
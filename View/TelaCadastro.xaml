<Window x:Class="TCC_Assiduidade.View.TelaCadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Cadastro"
        Height="499"
        Width="675"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Tela de Importação de Cadastro"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Nome da Turma:"/>

            <!-- MODIFICAÇÃO 1: Adicionado o Binding para salvar o nome da turma digitado -->
            <TextBox x:Name="tbTurmaNome"
                     Text="{Binding TurmaNome, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,5,0,15"
                     VerticalContentAlignment="Center"/>

            <!-- MODIFICAÇÃO 2: Trocado 'Click' por 'Command' para acionar a importação -->
            <Button x:Name="buttonImportarCadastro"
                    Content="Importar CSV de Cadastro"
                    Command="{Binding ImportarCadastroCommand}"
                    Height="40"/>

            <!-- MODIFICAÇÃO 3: Trocado 'Click' por 'Command' para abrir a outra tela -->
            <Button Content="Abrir Tela de Presença"
                    Command="{Binding AbrirTelaPresencaCommand}"
                    Height="40"
                    Margin="0,10,0,0"/>

            <!-- MODIFICAÇÃO 4: Adicionado o Binding para exibir o log e IsReadOnly para o usuário não apagar sem querer -->
            <TextBox x:Name="tbDados"
                     Text="{Binding TbDados, Mode=OneWay}"
                     IsReadOnly="True"
                     Margin="0,20,0,0"
                     Height="220"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

    </Grid>
</Window>
<Window x:Class="TCC_Assiduidade.View.TelaMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Menu"
        Height="720"
        Width="1100"
        MinHeight="650"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="72"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Grid Margin="56">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Menu Principal"
                   FontSize="40"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   Text="Escolha qual tela deseja abrir."
                   FontSize="24"
                   HorizontalAlignment="Center"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Importar Cadastro"
                    Command="{Binding AbrirTelaCadastroCommand}"/>

            <Button Grid.Column="2"
                    Content="Importar Presenca"
                    Command="{Binding AbrirTelaPresencaCommand}"/>

            <Button Grid.Column="4"
                    Content="Relatorios de Aulas"
                    Command="{Binding AbrirTelaRelatoriosAulasCommand}"/>

        </Grid>
    </Grid>
</Window>

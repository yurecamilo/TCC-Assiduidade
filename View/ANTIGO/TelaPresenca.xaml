<Window x:Class="TCC_Assiduidade.View.ANTIGO.TelaPresenca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Presenca"
        Height="720"
        Width="1100"
        MinHeight="650"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="54"/>
            <Setter Property="Padding" Value="18,8"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="56">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Tela de Importacao de Presenca"
                   FontSize="36"
                   FontWeight="Bold"/>

        <TextBlock Grid.Row="2"
                   Text="Turma:"
                   FontWeight="SemiBold"/>

        <ComboBox x:Name="cbTurmas"
                  Grid.Row="4"
                  ItemsSource="{Binding Turmas}"
                  SelectedItem="{Binding TurmaSelecionada, Mode=TwoWay}"
                  DisplayMemberPath="Nome"
                  Height="54"
                  VerticalContentAlignment="Center"/>

        <Button Grid.Row="6"
                Content="Importar CSV de Presenca"
                Command="{Binding ImportarPresencaCommand}"/>

        <DataGrid Grid.Row="8"
                  ItemsSource="{Binding Ausentes}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Aula" Binding="{Binding AulaId}" Width="*"/>
                <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat={}{0:dd/MM/yyyy}}" Width="*"/>
                <DataGridTextColumn Header="Turma" Binding="{Binding Turma}" Width="2*"/>
                <DataGridTextColumn Header="Matricula" Binding="{Binding Matricula}" Width="*"/>
                <DataGridTextColumn Header="Aluno" Binding="{Binding Aluno}" Width="2*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

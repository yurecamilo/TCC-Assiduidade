<Window x:Class="TCC_Assiduidade.View.ANTIGO.TelaCadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Cadastro"
        Height="720"
        Width="1100"
        MinHeight="650"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="54"/>
            <Setter Property="Padding" Value="18,8"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="56">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Tela de Importacao de Cadastro"
                   FontSize="36"
                   FontWeight="Bold"/>

        <TextBlock Grid.Row="2"
                   Text="Nome da Turma:"
                   FontWeight="SemiBold"/>

        <TextBox x:Name="tbTurmaNome"
                 Grid.Row="4"
                 Text="{Binding TurmaNome, UpdateSourceTrigger=PropertyChanged}"
                 Height="54"
                 VerticalContentAlignment="Center"/>

        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="buttonImportarCadastro"
                        Grid.Column="0"
                        Content="Importar CSV de Cadastro"
                        Command="{Binding ImportarCadastroCommand}"/>

                <Button Grid.Column="2"
                        Content="Abrir Tela de Presenca"
                        Command="{Binding AbrirTelaPresencaCommand}"/>
            </Grid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding AlunosImportados}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Matricula" Binding="{Binding Matricula}" Width="*"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#11181C" Padding="15,40,15,15">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnDashboard" Style="{StaticResource MenuButtonStyle}" Click="BtnDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconeHome}" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Início" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnTurmas" Style="{StaticResource MenuButtonStyle}" Click="BtnTurmas_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconeTurmas}" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" 
                                  Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Turmas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAlunos" Style="{StaticResource MenuButtonStyle}" Click="BtnAlunos_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconeAlunos}" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" 
                                  Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Alunos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRelatorios" Style="{StaticResource MenuButtonStyle}" Click="BtnRelatorios_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconeRelatorios}" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" 
                                  Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Relatórios" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <ContentControl x:Name="ConteudoPrincipal" Margin="0,0,0,20"/>
        </Grid>
    </Grid>
</Window>
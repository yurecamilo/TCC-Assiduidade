<Window x:Class="TCC_Assiduidade.TelaCadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Cadastro"
        Height="499"
        Width="675"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Tela de Importação de Cadastro"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Nome da Turma:"/>

            <TextBox x:Name="tbTurmaNome"
                     Height="30"
                     Margin="0,5,0,15"/>

            <Button x:Name="buttonImportarCadastro"
                    Content="Importar CSV de Cadastro"
                    Height="40"
                    Click="buttonImportarCadastro_Click"/>

            <Button Content="Abrir Tela de Presença"
                    Height="40"
                    Margin="0,10,0,0"
                    Click="buttonAbrirTelaPresenca_Click"/>

            <TextBox x:Name="tbDados"
                     Margin="0,20,0,0"
                     Height="220"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

    </Grid>
</Window>

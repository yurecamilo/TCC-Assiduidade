<Window x:Class="TCC_Assiduidade.TelaPresenca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar Presença"
        Height="499"
        Width="675"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Tela de Importação de Presença"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="ID da Turma:"/>

            <TextBox x:Name="tbTurmaId"
                     Height="30"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Data da Aula:"/>

            <DatePicker x:Name="dpDataAula"
                        Margin="0,5,0,15"/>

            <Button Content="Importar CSV de Presença"
                    Height="40"
                    Click="buttonImportarPresenca_Click"/>

            <TextBox x:Name="tbDados"
                     Margin="0,20,0,0"
                     Height="180"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

    </Grid>
</Window>